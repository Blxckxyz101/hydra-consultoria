# ══════════════════════════════════════════════════════
#  Lelouch Britannia — Variáveis de Ambiente
#  Copie para .env e preencha os valores reais
# ══════════════════════════════════════════════════════

# ── Telegram Bot ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUVwxyz

# ── Discord Bot ───────────────────────────────────────
DISCORD_BOT_TOKEN=MTA...seu_token_aqui
DISCORD_CLIENT_ID=123456789012345678
DISCORD_GUILD_ID=123456789012345678

# ── SkynetChat (cookies da sessão) ────────────────────
SKYNETCHAT_COOKIE=session_id=abc123...

# ── Webshare Proxies ──────────────────────────────────
# Credenciais do plano Residential Brazil (para desbloquear serviços geo-bloqueados)
WEBSHARE_PROXY_PASS=usuario:senha@proxy.webshare.io:80

# ── API Server ────────────────────────────────────────
PORT=8080
NODE_ENV=production

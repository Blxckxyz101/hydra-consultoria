# =============================================================================
# Hydra Consultoria — variáveis de ambiente necessárias
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA commite o arquivo .env ou qualquer arquivo com credenciais reais.
# =============================================================================

# ---------------------------------------------------------------------------
# API / OSINT providers
# ---------------------------------------------------------------------------
GEASS_API_KEY=your_geass_api_key_here
SKYLERS_TOKEN=your_skylers_token_here
DARKFLOW_TOKEN=your_darkflow_token_here

# ---------------------------------------------------------------------------
# Proxy residencial (Webshare)
# ---------------------------------------------------------------------------
WEBSHARE_PROXY_USER=your_webshare_username
WEBSHARE_PROXY_PASS=your_webshare_password
WEBSHARE_PROXY_LIST=host1:port1,host2:port2

RESIDENTIAL_HOST=proxy.example.com
RESIDENTIAL_PORT=8080
RESIDENTIAL_USER=your_residential_user
RESIDENTIAL_PASS=your_residential_password
RESIDENTIAL_COUNT=1000

# ---------------------------------------------------------------------------
# SkyNetChat
# ---------------------------------------------------------------------------
SKYNETCHAT_COOKIE=your_skynetchat_session_cookie
SKYNETCHAT_PRO_CODE=your_skynetchat_pro_code

# ---------------------------------------------------------------------------
# Painel admin
# ---------------------------------------------------------------------------
PANEL_SECRET=your_random_64char_hex_secret
VITE_PANEL_SECRET=same_value_as_panel_secret
PANEL_PIN=your_panel_pin
PANEL_URL=https://your-deployment-domain/api

# ---------------------------------------------------------------------------
# Pagamentos (NedPay)
# ---------------------------------------------------------------------------
NEDPAY_PUBLIC_KEY=your_nedpay_public_key
NEDPAY_PRIVATE_KEY=your_nedpay_private_key

# ---------------------------------------------------------------------------
# Bots (Telegram / Discord)
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
INFINITY_BOT_TOKEN=your_telegram_infinity_bot_token
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_APPLICATION_ID=your_discord_application_id
INFINITY_FREE_GROUPS=-1001234567890

# ---------------------------------------------------------------------------
# IA (Groq / OpenAI via AI Integrations proxy)
# ---------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key
AI_INTEGRATIONS_OPENAI_API_KEY=provided_by_replit_ai_integrations
AI_INTEGRATIONS_OPENAI_BASE_URL=provided_by_replit_ai_integrations

# ---------------------------------------------------------------------------
# SMTP (e-mail)
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@example.com

# ---------------------------------------------------------------------------
# Banco de dados / cluster
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/hydra
CLUSTER_NODES=

# ---------------------------------------------------------------------------
# GitHub (push automático)
# ---------------------------------------------------------------------------
GH_TOKEN=your_github_personal_access_token

# Chat/canal que recebe alertas quando o push falha.
# Use @username para canais públicos ou o numeric ID para grupos/canais privados.
# O bot INFINITY_BOT_TOKEN precisa ser admin do canal para enviar mensagens.
TELEGRAM_NOTIFY_CHAT_ID=@hydraconsultoria

# ---------------------------------------------------------------------------
# Servidor
# ---------------------------------------------------------------------------
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
API_KEY=your_internal_api_key
